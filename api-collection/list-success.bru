meta {
  name: List Anime - Success with Pagination
  type: http
  seq: 4
}

post {
  url: {{base_url}}/{{api_version}}/anime/list
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "page": 1,
    "limit": 10,
    "genre": "action",
    "status": "ongoing",
    "sortBy": "popularity",
    "order": "desc"
  }
}